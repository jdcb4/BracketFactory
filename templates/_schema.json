{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bracketfactory.local/schemas/template.json",
  "title": "BracketFactory template",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "category",
    "version",
    "generationStrategy",
    "units",
    "parameters",
    "preview"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "category": { "type": "string" },
    "version": { "type": "string" },
    "generationStrategy": { "type": "string", "minLength": 1 },
    "units": { "const": "mm" },
    "disabled": { "type": "boolean" },
    "disabledReason": { "type": "string" },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/parameter" }
    },
    "preview": {
      "type": "object",
      "required": ["cameraPosition", "target"],
      "properties": {
        "cameraPosition": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "number" }
        },
        "target": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "number" }
        }
      }
    }
  },
  "definitions": {
    "parameter": {
      "type": "object",
      "required": ["key", "label", "type", "default", "group"],
      "additionalProperties": true,
      "properties": {
        "key": { "type": "string" },
        "label": { "type": "string" },
        "type": {
          "enum": ["number", "integer", "boolean", "select", "string"]
        },
        "default": {},
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "group": {
          "enum": [
            "dimensions",
            "hardware",
            "fit",
            "reinforcement",
            "print",
            "advanced"
          ]
        },
        "unit": { "type": "string" },
        "advanced": { "type": "boolean" },
        "uiHint": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "label"],
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
